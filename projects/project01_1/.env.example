# OpenAI API 配置
# 选项 1: 使用官方 OpenAI API
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# 选项 2: 使用本地 Ollama（推荐）
OPENAI_API_KEY=ollama
OPENAI_API_BASE=http://192.168.3.27:11434/v1
OPENAI_MODEL=qwen3.5:27b

# 其他 API 密钥（可选）
WEATHER_API_KEY=

# 缓存配置
CACHE_ENABLED=true
CACHE_TTL=3600

# 对话配置
MAX_HISTORY_MESSAGES=10

# 调试模式
DEBUG=false
